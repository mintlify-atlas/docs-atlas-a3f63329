  "keyFeatures": [
    "Annual Work Plan (PTA) creation and management",
    "Personnel management with departments and positions",
    "Role-based access control and authentication",
    "Multi-level approval workflow (responsible, supervisor, aval)",
    "Indicators and actions tracking",
    "Email notifications for user creation and password recovery",
    "Admin dashboard for system management",
    "PostgreSQL database with Doctrine ORM"
  ],
  "publicApiSurface": [
    "EncabezadoController: Create, edit, view, and delete PTAs",
    "PersonalController: Manage personnel records",
    "DepartamentoController: Manage departments",
    "PuestoController: Manage positions",
    "SecurityController: User authentication",
    "RecuperarPasswordController: Password recovery workflow",
    "AdminPersonalApiController: Personnel API endpoints",
    "Entity\\Encabezado: PTA header with objectives and metadata",
    "Entity\\Personal: Staff members with department and position",
    "Entity\\Indicadores: Performance indicators for PTAs",
    "Entity\\Acciones: Action items within PTAs",
    "Entity\\Responsables: Approval hierarchy (supervisor and aval)",
    "Service\\UserCreator: User account creation",
    "Service\\WelcomeMailer: Welcome email notifications",
    "Service\\RecuperarPassword: Password recovery logic"
  ]
}
